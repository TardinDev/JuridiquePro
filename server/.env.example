# ─── DEVELOPMENT ───────────────────────────────────────
# En dev, SQLite est utilisé automatiquement (pas besoin de DATABASE_URL)
# En production sur Render, PostgreSQL est utilisé via DATABASE_URL

# Database (PostgreSQL — uniquement en production)
# Sur Render: utiliser l'Internal Database URL fournie automatiquement
DATABASE_URL=

# JWT Secret (utiliser une clé forte en production)
# Sur Render: généré automatiquement via render.yaml
JWT_SECRET=dev-secret-change-in-production

# Environment (development | production)
NODE_ENV=development

# Port du serveur
PORT=3001

# Frontend URL (pour CORS — adapter en production)
FRONTEND_URL=http://localhost:5173

# ─── EMAIL (Resend — optionnel) ────────────────────────
# Clé API Resend pour envoyer des emails transactionnels
# Sans cette clé, les emails sont loggés dans la console
RESEND_API_KEY=

# Email expéditeur (nécessite un domaine vérifié sur Resend)
FROM_EMAIL=Juridique Pro <noreply@projuridique.com>

# Email admin pour recevoir les notifications
ADMIN_EMAIL=nze.claudia@yahoo.fr

# ─── CHATBOT (Anthropic — optionnel) ───────────────────
# Clé API Anthropic pour le chatbot IA
# Sans cette clé, le chatbot utilise des réponses prédéfinies
ANTHROPIC_API_KEY=

# Modèle à utiliser (haiku par défaut pour la rapidité et le coût)
CHAT_MODEL=claude-haiku-4-5-20251001

# ─── SEED ADMIN AUTOMATIQUE ────────────────────────────
# Au premier démarrage, si aucun admin n'existe et que ces variables
# sont définies, un compte admin est créé automatiquement.
# IMPORTANT : à définir sur Render pour ne plus jamais perdre l'accès admin.
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_NAME=Admin

# Désactiver le seed du contenu homepage par défaut (true par défaut)
# SEED_HOMEPAGE_CONTENT=false
